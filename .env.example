# ============================================
# Electricity Cost AI - Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Database (Snowflake) ---
DB_SNOWFLAKE_ACCOUNT=your_account.us-east-1
DB_SNOWFLAKE_USER=your_user
DB_SNOWFLAKE_PASSWORD=your_password
DB_SNOWFLAKE_DATABASE=ELECTRICITY_DW
DB_SNOWFLAKE_SCHEMA=PUBLIC
DB_SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_REDIS_URL=redis://localhost:6379/0
API_CACHE_TTL_SECONDS=300

# --- External Data Sources ---
DATA_EIA_API_KEY=your_eia_api_key
DATA_NOAA_TOKEN=your_noaa_token
DATA_PJM_API_KEY=your_pjm_api_key

# --- MLflow ---
MODEL_MLFLOW_TRACKING_URI=./mlruns
MODEL_MLFLOW_EXPERIMENT_NAME=electricity_cost_analysis
